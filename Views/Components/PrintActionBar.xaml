<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowsPrinter.Views.Components.PrintActionBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:WindowsPrinter.ViewModels"
    d:DataContext="{d:DesignInstance vm:PrintWorkspaceViewModel, IsDesignTimeCreatable=False}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        Padding="16,12"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="0,1,0,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="{Binding Queue.SelectionSummary}" />

        <StackPanel
            Grid.Column="1"
            Orientation="Horizontal"
            Spacing="12">
            <Button
                Content="取消打印"
                Visibility="{Binding IsPrinting, Converter={StaticResource BoolToVis}}"
                Command="{Binding CancelPrintCommand}" />
            <Button
                Content="开始打印"
                Style="{ThemeResource AccentButtonStyle}"
                Command="{Binding StartPrintCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
