<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowsPrinter.Views.Components.PrintActionBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:WindowsPrinter.ViewModels"
    d:DataContext="{d:DesignInstance vm:PrintWorkspaceViewModel, IsDesignTimeCreatable=False}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="ActionRoot"
        Padding="24,12"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="0,1,0,0">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="WidthStates">
                <VisualState x:Name="Wide">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1280" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ActionRoot.Padding" Value="24,12" />
                        <Setter Target="ActionButtons.Spacing" Value="12" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Standard">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="1008" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="ActionRoot.Padding" Value="20,12" />
                        <Setter Target="ActionButtons.Spacing" Value="8" />
                    </VisualState.Setters>
                </VisualState>
                <VisualState x:Name="Compact">
                    <VisualState.Setters>
                        <Setter Target="ActionRoot.Padding" Value="12,8" />
                        <Setter Target="ActionButtons.Spacing" Value="8" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="0" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            VerticalAlignment="Center"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="{Binding Queue.SelectionSummary}"
            TextTrimming="CharacterEllipsis" />

        <ScrollViewer
            Grid.Row="0"
            Grid.Column="1"
            HorizontalAlignment="Right"
            HorizontalScrollBarVisibility="Auto"
            HorizontalScrollMode="Auto"
            VerticalScrollBarVisibility="Disabled"
            VerticalScrollMode="Disabled"
            ZoomMode="Disabled">
            <StackPanel
                x:Name="ActionButtons"
                Orientation="Horizontal"
                Spacing="8">
                <Button
                    AutomationProperties.Name="重试失败项"
                    Content="重试失败"
                    Command="{Binding RetryFailedCommand}" />
                <Button
                    AutomationProperties.Name="预览选中文件"
                    Content="预览"
                    Command="{Binding PreviewSelectedCommand}" />
                <Button
                    AutomationProperties.Name="取消打印"
                    Content="取消打印"
                    Visibility="{Binding IsPrinting, Converter={StaticResource BoolToVis}}"
                    Command="{Binding CancelPrintCommand}" />
                <Button
                    AutomationProperties.Name="开始打印"
                    Content="开始打印"
                    Style="{ThemeResource AccentButtonStyle}"
                    Command="{Binding StartPrintCommand}" />
            </StackPanel>
        </ScrollViewer>

        <ProgressBar
            Grid.Row="1"
            Grid.ColumnSpan="2"
            Margin="0,8,0,0"
            Maximum="100"
            Value="{Binding PrintProgressPercent, Mode=OneWay}"
            Visibility="{Binding ShowPrintProgress, Converter={StaticResource BoolToVis}}" />
    </Grid>
</UserControl>
