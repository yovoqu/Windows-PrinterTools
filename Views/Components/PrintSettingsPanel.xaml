<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowsPrinter.Views.Components.PrintSettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:WindowsPrinter.Models"
    xmlns:vm="using:WindowsPrinter.ViewModels"
    d:DataContext="{d:DesignInstance vm:PrintSettingsViewModel, IsDesignTimeCreatable=False}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalContentAlignment="Stretch"
    VerticalContentAlignment="Stretch"
    mc:Ignorable="d">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        VerticalAlignment="Stretch"
        VerticalScrollBarVisibility="Auto"
        ZoomMode="Disabled">
        <StackPanel Padding="16,12,16,20" Spacing="12">
            <TextBlock
                Style="{ThemeResource SubtitleTextBlockStyle}"
                Text="打印选项" />

            <Border
                Padding="16"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="4">
                        <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="打印机" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Text="选择本机已安装的打印机"
                            TextWrapping="WrapWholeWords" />
                    </StackPanel>
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        IsEnabled="{Binding IsPrinterComboEnabled}"
                        ItemsSource="{Binding Printers}"
                        PlaceholderText="从列表中选择..."
                        SelectedItem="{Binding SelectedPrinter, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:PrinterInfo">
                                <TextBlock
                                    Padding="0,4"
                                    Text="{x:Bind DisplayName}"
                                    TextWrapping="WrapWholeWords" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button
                            Command="{Binding RefreshPrintersCommand}"
                            Content="刷新列表" />
                        <ProgressRing
                            Width="20"
                            Height="20"
                            IsActive="{Binding IsLoadingPrinters}"
                            Visibility="{Binding IsLoadingPrinters, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                    <InfoBar
                        IsClosable="False"
                        IsOpen="{Binding HasPrinterLoadError}"
                        Message="{Binding PrinterLoadError}"
                        Severity="Warning" />
                </StackPanel>
            </Border>

            <Border
                Padding="16"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="色彩模式" />
                        <ToggleSwitch
                            OffContent="黑白"
                            OnContent="彩色"
                            IsOn="{Binding UseColor, Mode=TwoWay}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="份数" />
                        <NumberBox
                            Minimum="1"
                            Maximum="99"
                            SpinButtonPlacementMode="Inline"
                            Value="{Binding Copies, Mode=TwoWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border
                Padding="16"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <StackPanel Spacing="8">
                    <TextBlock Style="{ThemeResource BodyStrongTextBlockStyle}" Text="双面打印" />
                    <ComboBox
                        HorizontalAlignment="Stretch"
                        DisplayMemberPath="Label"
                        ItemsSource="{Binding DuplexOptions}"
                        SelectedItem="{Binding SelectedDuplexOption, Mode=TwoWay}" />
                </StackPanel>
            </Border>

            <Expander Header="高级设置" IsExpanded="False">
                <StackPanel Padding="0,8,0,4" Spacing="8">
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="系统关联打印（Office / WebP）提交到队列后的等待时间。"
                        TextWrapping="WrapWholeWords" />
                    <NumberBox
                        Header="Shell 队列超时（秒）"
                        Minimum="15"
                        Maximum="300"
                        SpinButtonPlacementMode="Inline"
                        Value="{Binding ShellSpoolerTimeoutSeconds, Mode=TwoWay}" />
                </StackPanel>
            </Expander>

            <Expander Header="支持的文件格式" IsExpanded="False">
                <StackPanel Padding="0,8,0,4" Spacing="4">
                    <TextBlock Text="PDF：.pdf（支持预览）" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="图片：.jpg .jpeg .png .bmp .gif .tif .tiff（支持预览）" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="Office / 系统关联：.doc .docx .xls .xlsx .ppt .pptx .rtf .webp" TextWrapping="WrapWholeWords" />
                    <TextBlock Text="文本：.txt .log .md .csv（支持预览）" TextWrapping="WrapWholeWords" />
                </StackPanel>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
