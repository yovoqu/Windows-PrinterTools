<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowsPrinter.Views.Components.PrintQueuePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:WindowsPrinter.Models"
    xmlns:tv="using:WinUI.TableView"
    xmlns:vm="using:WindowsPrinter.ViewModels"
    d:DataContext="{d:DesignInstance vm:PrintQueueViewModel, IsDesignTimeCreatable=False}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" IsDynamicOverflowEnabled="True" IsOpen="False">
            <AppBarButton
                AutomationProperties.Name="添加文件"
                Label="添加文件"
                Command="{Binding AddFilesCommand}">
                <AppBarButton.Icon>
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="{StaticResource AppGlyphAdd}" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                AutomationProperties.Name="添加文件夹"
                Label="添加文件夹"
                Command="{Binding AddFolderCommand}">
                <AppBarButton.Icon>
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="{StaticResource AppGlyphFolder}" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                AutomationProperties.Name="全选"
                Label="全选"
                Command="{Binding SelectAllCommand}">
                <AppBarButton.Icon>
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="{StaticResource AppGlyphSelectAll}" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                AutomationProperties.Name="取消选择"
                Label="取消选择"
                Command="{Binding ClearSelectionCommand}">
                <AppBarButton.Icon>
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="{StaticResource AppGlyphClearSelection}" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarButton
                AutomationProperties.Name="移除选中文件"
                Label="移除"
                Command="{Binding RemoveSelectedCommand}">
                <AppBarButton.Icon>
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="{StaticResource AppGlyphDelete}" />
                </AppBarButton.Icon>
            </AppBarButton>
            <AppBarSeparator />
            <AppBarButton
                AutomationProperties.Name="清空队列"
                Label="清空队列"
                Command="{Binding ClearQueueCommand}">
                <AppBarButton.Icon>
                    <FontIcon
                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                        Glyph="{StaticResource AppGlyphClear}" />
                </AppBarButton.Icon>
            </AppBarButton>
            <CommandBar.Content>
                <AutoSuggestBox
                    MinWidth="160"
                    MaxWidth="320"
                    HorizontalAlignment="Stretch"
                    PlaceholderText="搜索文件名或路径..."
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <AutoSuggestBox.QueryIcon>
                        <FontIcon
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            Glyph="{StaticResource AppGlyphFind}" />
                    </AutoSuggestBox.QueryIcon>
                </AutoSuggestBox>
            </CommandBar.Content>
        </CommandBar>

        <tv:TableView
            x:Name="QueueTable"
            Grid.Row="1"
            Margin="0,8,0,0"
            AllowDrop="True"
            AutoGenerateColumns="False"
            CanResizeColumns="True"
            GridLinesVisibility="Horizontal"
            IsReadOnly="True"
            ItemsSource="{Binding DisplayedFiles}"
            SelectionMode="None"
            Visibility="{Binding HasFiles, Converter={StaticResource BoolToVis}}">
            <tv:TableView.Columns>
                <tv:TableViewTemplateColumn Header="选择" Width="56">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:PrintFileItem">
                            <CheckBox
                                HorizontalAlignment="Center"
                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTextColumn
                    Header="文件名"
                    Binding="{Binding FileName}"
                    Width="240" />
                <tv:TableViewTextColumn
                    Header="路径"
                    Binding="{Binding DisplayPath}"
                    Width="320" />
                <tv:TableViewTextColumn
                    Header="类型"
                    Binding="{Binding FileTypeText}"
                    Width="100" />
                <tv:TableViewTextColumn
                    Header="方式"
                    Binding="{Binding HandlerText}"
                    Width="120" />
                <tv:TableViewTextColumn
                    Header="大小"
                    Binding="{Binding FileSizeText}"
                    Width="80" />
                <tv:TableViewTemplateColumn Header="状态" Width="140">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:PrintFileItem">
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{x:Bind StatusText, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
            </tv:TableView.Columns>
        </tv:TableView>

        <StackPanel
            Grid.Row="1"
            Margin="0,48,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="16"
            Visibility="{Binding IsQueueEmpty, Converter={StaticResource BoolToVis}}">
            <FontIcon
                FontSize="48"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Glyph="&#xE8A5;" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="队列为空，添加或拖放文件开始打印" />
            <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" Spacing="12">
                <Button
                    AutomationProperties.Name="添加文件"
                    Content="添加文件"
                    Style="{ThemeResource AccentButtonStyle}"
                    Command="{Binding AddFilesCommand}" />
                <Button
                    AutomationProperties.Name="添加文件夹"
                    Content="添加文件夹"
                    Command="{Binding AddFolderCommand}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
