<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="WindowsPrinter.Views.Components.PrintQueuePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:WindowsPrinter.Models"
    xmlns:tv="using:WinUI.TableView"
    xmlns:vm="using:WindowsPrinter.ViewModels"
    d:DataContext="{d:DesignInstance vm:PrintQueueViewModel, IsDesignTimeCreatable=False}"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" IsOpen="False">
            <AppBarButton
                Icon="Add"
                Label="添加文件"
                Command="{Binding AddFilesCommand}" />
            <AppBarButton
                Icon="OpenFolder"
                Label="添加文件夹"
                Command="{Binding AddFolderCommand}" />
            <AppBarSeparator />
            <AppBarButton
                Icon="SelectAll"
                Label="全选"
                Command="{Binding SelectAllCommand}" />
            <AppBarButton
                Icon="ClearSelection"
                Label="取消选择"
                Command="{Binding ClearSelectionCommand}" />
            <AppBarButton
                Icon="Delete"
                Label="移除"
                Command="{Binding RemoveSelectedCommand}" />
            <CommandBar.Content>
                <AutoSuggestBox
                    MinWidth="220"
                    PlaceholderText="搜索文件名或路径..."
                    QueryIcon="Find"
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </CommandBar.Content>
        </CommandBar>

        <tv:TableView
            x:Name="QueueTable"
            Grid.Row="1"
            Margin="0,8,0,0"
            AutoGenerateColumns="False"
            CanResizeColumns="True"
            GridLinesVisibility="Horizontal"
            IsReadOnly="True"
            ItemsSource="{Binding DisplayedFiles}"
            SelectionMode="None"
            Visibility="{Binding HasFiles, Converter={StaticResource BoolToVis}}">
            <tv:TableView.Columns>
                <tv:TableViewTemplateColumn Header="选择" Width="56">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:PrintFileItem">
                            <CheckBox
                                HorizontalAlignment="Center"
                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
                <tv:TableViewTextColumn
                    Header="文件名"
                    Binding="{Binding FileName}"
                    Width="2*" />
                <tv:TableViewTextColumn
                    Header="路径"
                    Binding="{Binding DisplayPath}"
                    Width="2*" />
                <tv:TableViewTextColumn
                    Header="类型"
                    Binding="{Binding FileTypeText}"
                    Width="120" />
                <tv:TableViewTextColumn
                    Header="大小"
                    Binding="{Binding FileSizeText}"
                    Width="80" />
                <tv:TableViewTemplateColumn Header="状态" Width="140">
                    <tv:TableViewTemplateColumn.CellTemplate>
                        <DataTemplate x:DataType="models:PrintFileItem">
                            <TextBlock
                                VerticalAlignment="Center"
                                Text="{x:Bind StatusText, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </tv:TableViewTemplateColumn.CellTemplate>
                </tv:TableViewTemplateColumn>
            </tv:TableView.Columns>
        </tv:TableView>

        <StackPanel
            Grid.Row="1"
            Margin="0,48,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="16"
            Visibility="{Binding IsQueueEmpty, Converter={StaticResource BoolToVis}}">
            <FontIcon
                FontSize="48"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Glyph="&#xE8A5;" />
            <TextBlock
                HorizontalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="队列为空，添加文件或文件夹开始打印" />
            <Button
                HorizontalAlignment="Center"
                Content="添加文件"
                Style="{ThemeResource AccentButtonStyle}"
                Command="{Binding AddFilesCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
