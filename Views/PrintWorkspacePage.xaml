<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="WindowsPrinter.Views.PrintWorkspacePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:components="using:WindowsPrinter.Views.Components"
    xmlns:local="using:WindowsPrinter.Views"
    x:DataType="local:PrintWorkspacePage">

    <Grid Padding="24,16" DataContext="{x:Bind ViewModel, Mode=OneWay}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="4">
            <TextBlock Style="{ThemeResource TitleTextBlockStyle}" Text="文件打印" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="添加文件或文件夹，选择打印机后开始批量打印。" />
        </StackPanel>

        <TwoPaneView
            Grid.Row="1"
            MinWideModeWidth="960"
            Pane1Length="2*"
            Pane2Length="*">
            <TwoPaneView.Pane1>
                <components:PrintQueuePanel DataContext="{Binding Queue, Mode=OneWay}" />
            </TwoPaneView.Pane1>
            <TwoPaneView.Pane2>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <components:PrintSettingsPanel
                        Padding="16,0,0,0"
                        DataContext="{Binding Settings, Mode=OneWay}" />
                </ScrollViewer>
            </TwoPaneView.Pane2>
        </TwoPaneView>

        <InfoBar
            Grid.Row="2"
            Margin="0,12,0,0"
            IsClosable="True"
            IsOpen="{Binding IsStatusOpen, Mode=TwoWay}"
            Message="{Binding StatusMessage, Mode=OneWay}"
            Severity="{Binding StatusSeverity, Converter={StaticResource SeverityToInfoBar}}" />

        <components:PrintActionBar Grid.Row="3" Margin="-24,-16" />
    </Grid>
</Page>
